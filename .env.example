TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
TELEGRAM_ALLOWED_USER_ID="YOUR_USER_ID_HERE"

# Choose your provider: 'gemini', 'openrouter', or 'custom'
LLM_PROVIDER="custom"

# Custom Local/OpenAI-compatible API Configuration
CUSTOM_API_KEY="YOUR_LOCAL_API_KEY_HERE"
CUSTOM_BASE_URL="http://localhost:11434/v1"

GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"
CARTESIA_API_KEY="YOUR_CARTESIA_API_KEY_HERE"

# Failover Configuration
LLM_FAILOVER_PRIORITY=anthropic,openai,google,groq
LLM_FAILOVER_TIMEOUT=10  # Seconds before failing over to the next provider
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# GitHub MCP token (injected into child process via process.env)
GITHUB_PERSONAL_ACCESS_TOKEN="github_pat_..."
