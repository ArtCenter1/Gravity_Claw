    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "cross-port-killer": "^1.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
